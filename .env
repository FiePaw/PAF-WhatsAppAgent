# ================================
# WhatsApp Bot Configuration
# ================================

# Nomor owner (format: 6281234567890 tanpa + atau @s.whatsapp.net)
OWNER_NUMBER=6281234567890

# LID owner — isi dari log "sender" saat pertama kali kirim pesan
# Contoh: jika log menampilkan sender: "225545979723871" maka isi 225545979723871
# Kosongkan jika tidak tahu (bot akan coba resolve otomatis)
OWNER_LID=225545979723871

# Prefix command (bisa diganti)
BOT_PREFIX=!

# OpenAI-Compatible API Server
AI_API_URL=http://108.137.15.61:9000
AI_MODEL=qwen

# Session TTL untuk in-memory session store (ms) — default 1 jam
SESSION_TTL=86400000

# Status online saat bot connect (true/false)
MARK_ONLINE=true

# Auto baca pesan masuk → centang biru (true/false)
AUTO_READ=true

# Anti-spam delay per karakter (ms), 0 untuk nonaktifkan
CHAR_DELAY_MS=40

# Max delay (ms) untuk pesan sangat panjang
MAX_DELAY_MS=4000

# Log level: trace | debug | info | warn | error
LOG_LEVEL=debug
